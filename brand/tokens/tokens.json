{
  "$schema": "https://design-tokens.org/schema.json",
  "color": {
    "navy": {
      "950": { "$value": "#0F172A", "$type": "color" },
      "800": { "$value": "#1E3A8A", "$type": "color" }
    },
    "or": {
      "700": { "$value": "#A16207", "$type": "color" },
      "400": { "$value": "#D4A053", "$type": "color" }
    },
    "ivoire": { "$value": "#F8FAFC", "$type": "color" },
    "ardoise": {
      "500": { "$value": "#64748B", "$type": "color" },
      "950": { "$value": "#020617", "$type": "color" }
    },
    "blanc": { "$value": "#FFFFFF", "$type": "color" },
    "destructive": { "$value": "#DC2626", "$type": "color" }
  },
  "font": {
    "title":   { "$value": "Manrope, system-ui, sans-serif", "$type": "fontFamily" },
    "tracked": { "$value": "Inter, system-ui, sans-serif", "$type": "fontFamily" },
    "body":    { "$value": "'Source Sans 3', system-ui, sans-serif", "$type": "fontFamily" },
    "mono":    { "$value": "'JetBrains Mono', monospace", "$type": "fontFamily" }
  },
  "fontWeight": {
    "regular":  { "$value": 400, "$type": "fontWeight" },
    "medium":   { "$value": 500, "$type": "fontWeight" },
    "semibold": { "$value": 600, "$type": "fontWeight" },
    "bold":     { "$value": 700, "$type": "fontWeight" }
  },
  "letterSpacing": {
    "title":   { "$value": "-0.02em", "$type": "dimension" },
    "tracked": { "$value": "0.28em", "$type": "dimension" },
    "tracked-wide": { "$value": "0.55em", "$type": "dimension" }
  }
}
